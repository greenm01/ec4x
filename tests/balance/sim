#!/usr/bin/env bash
# Wrapper script for run_simulation with helpful error messages

set -e

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
BINARY="$SCRIPT_DIR/run_simulation"

# Show help if requested or no arguments
if [[ $# -eq 0 ]] || [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]] || [[ "$1" == "help" ]]; then
    echo "Usage: sim TURNS [SEED] [MAP_RINGS] [NUM_PLAYERS]"
    echo ""
    echo "Arguments:"
    echo "  TURNS       Number of game turns to simulate (required)"
    echo "  SEED        Random seed for map generation (default: 42)"
    echo "  MAP_RINGS   Number of hex rings for map (default: NUM_PLAYERS)"
    echo "  NUM_PLAYERS Number of AI players (default: 4)"
    echo ""
    echo "Examples:"
    echo "  sim 30 88888 4 4    # 30 turns, seed 88888, 4 rings, 4 players"
    echo "  sim 7 12345         # 7 turns, seed 12345, defaults for rest"
    echo "  sim 15              # 15 turns, default seed and settings"
    exit 0
fi

# Execute the binary with all arguments
exec "$BINARY" "$@"
